{
  "name": "andrii-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "extract-tokens": "node scripts/extract-tokens.js",
    "optimize:images": "node scripts/optimize-images.js",
    "optimize:videos": "node scripts/optimize-videos.js",
    "optimize": "npm run optimize:images && npm run optimize:videos",
    "prepare-build": "node -e \"if(process.env.ASSETS_OPTIMIZE==='true'){require('child_process').execSync('npm run optimize',{stdio:'inherit'})}\""
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@vercel/speed-insights": "^2.0.0",
    "autoprefixer": "^10.4.24",
    "framer-motion": "^12.30.0",
    "next": "16.1.6",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5"
  }
}
